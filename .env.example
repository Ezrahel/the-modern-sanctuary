# Local development only — copy to .env (never commit .env).
# On Vercel: add each NAME in the dashboard separately; VALUE is only the value (see below).

GEMINI_API_KEY=MY_GEMINI_API_KEY

# Optional for split frontend/API hosting. Leave unset for same-origin Vercel deploy.
APP_URL=

# Leave empty when frontend and /api/* are on the same Vercel URL.
VITE_API_BASE_URL=

VITE_PUBLIC_POSTHOG_KEY=phc_your_project_key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel → Environment Variables:
#   Name:  COCKROACH_DB_URL
#   Value: postgresql://USER:PASSWORD@HOST:26257/defaultdb?sslmode=require
# (one line only — no COCKROACH_DB_URL= prefix, no quotes, no # comments)
COCKROACH_DB_URL=postgresql://username:password@host:26257/defaultdb?sslmode=require
