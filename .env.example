# Local development only — copy to .env (never commit .env).

GEMINI_API_KEY=MY_GEMINI_API_KEY

APP_URL=

VITE_API_BASE_URL=

VITE_PUBLIC_POSTHOG_KEY=phc_your_project_key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel: Name = COCKROACH_DB_URL, Value = URL only (one line, no quotes or # comments)
COCKROACH_DB_URL=postgresql://username:password@host:26257/defaultdb?sslmode=require

# Admin (generate hash: node scripts/hash-admin-password.mjs "your-password")
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=generate-a-long-random-string
